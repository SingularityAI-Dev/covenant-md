{
  "name": "covenant-framework",
  "version": "1.0.0",
  "description": "Framework implementing the COVENANT.md specification for AI agent skills",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "validate": "node src/cli.js validate",
    "test": "npm run test:framework",
    "test:framework": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:fixtures": "node src/cli.js test examples/markdown-to-html/ && node src/cli.js test examples/pdf-generation/ && node src/cli.js test examples/template-rendering/ && node src/cli.js test examples/docx-generation/",
    "lint": "node src/cli.js lint",
    "diff": "node src/cli.js diff",
    "graph": "node src/cli.js graph",
    "generate": "node src/cli.js generate",
    "build": "echo 'Build complete'"
  },
  "jest": {
    "testEnvironment": "node",
    "transform": {},
    "testMatch": ["<rootDir>/tests/**/*.test.js"],
    "collectCoverage": true,
    "coverageReporters": ["text", "lcov"],
    "collectCoverageFrom": ["src/**/*.js"]
  },
  "keywords": [
    "covenant",
    "ai",
    "agent",
    "skill",
    "specification",
    "contract"
  ],
  "author": "AI Engineer",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^14.0.3",
    "handlebars": "^4.7.9",
    "inquirer": "^13.4.2",
    "jsonschema": "^1.4.1",
    "marked": "^9.0.0",
    "yaml": "^2.3.1"
  },
  "devDependencies": {
    "eslint": "^8.39.0",
    "jest": "^29.5.0"
  }
}
